# Copy this file to .env and fill in your real key:
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# .env is read by src/services/openai_service.py via python-dotenv (load_dotenv).

# Required: enables the OpenAI Function Calling path.
OPENAI_API_KEY=sk-your-key-here

# Optional: model override. Defaults to gpt-4o-mini if omitted.
OPENAI_MODEL=gpt-4o-mini

# Data backend for the tools: mock (offline/tests) or odoo (live, read-only).
DATA_BACKEND=mock

# Required only when DATA_BACKEND=odoo. ODOO_USERNAME must be the dedicated
# read-only account; see docs/ODOO_READONLY_USER.md. Startup refuses to run
# unless ODOO_USERNAME matches EXPECTED_ODOO_USER.
ODOO_URL=https://your-odoo-host
ODOO_DB=your-db-name
ODOO_USERNAME=AI_AGENT_READONLY
ODOO_PASSWORD=your-api-key-or-password
EXPECTED_ODOO_USER=AI_AGENT_READONLY

# Read by apps/api (FastAPI) only. Comma-separated list of origins allowed
# to call /health, /tools, /chat. Defaults to http://localhost:3000 if
# unset — only needed once apps/web is served from a real domain.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Required for apps/api's /chat and /tools (Phase 10) — apps/web signs a
# short-lived token with this same secret so apps/api can verify a request
# genuinely came from an authenticated session instead of trusting anyone
# who can reach it on the network. This value MUST exactly match
# apps/web's API_AUTH_SECRET (apps/web/.env.local for local dev — Docker
# Compose reuses this same root .env value for both containers
# automatically). Generate with:
#   openssl rand -base64 32
# 32+ bytes — HMAC-SHA256's recommended minimum key length (RFC 7518 §3.2).
# See docs/API_AUTHENTICATION.md for the full design.
API_AUTH_SECRET=replace-with-a-real-generated-secret-at-least-32-bytes
