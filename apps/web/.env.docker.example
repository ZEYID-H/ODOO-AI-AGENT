# Copy to .env.docker (already git-ignored) before running
# `docker compose -f docker-compose.saas.yml up`.
#
# Only secrets go here. Non-secret plumbing (DATABASE_URL, the internal API
# URL, AUTH_TRUST_HOST) is set directly in docker-compose.saas.yml since
# there's nothing sensitive about it — see that file's comments.
#
# NOT here: API_AUTH_SECRET (Phase 10) — it's a secret *shared* between
# apps/web and apps/api, so it's set once in the repo-root .env (next to
# apps/api's other config) and docker-compose.saas.yml injects that same
# value into both containers. See .env.example and docs/API_AUTHENTICATION.md.

# Signs/encrypts the session JWT cookie. Generate a real value with:
#   npx auth secret
# or:
#   openssl rand -base64 33
# Never reuse this placeholder as a real secret.
AUTH_SECRET=replace-with-a-real-generated-secret

# --- Account provisioning (Delivery D1) -------------------------------------
# Individual accounts replaced the single shared password. These are read by
# scripts/seed-users.ts on every container start (see docker-entrypoint.sh):
# accounts whose var is unset are skipped; set vars create the account or
# rotate its password. This is the ONLY account-creation mechanism — there
# is deliberately no user-management UI. If none are set, nobody can log in
# (fails closed, not open).
SEED_ADMIN_PASSWORD=replace-with-a-real-password
SEED_DRIVER_AHMED_PASSWORD=replace-with-a-real-password
SEED_DRIVER_MOHAMMED_PASSWORD=replace-with-a-real-password
SEED_DRIVER_ALI_PASSWORD=replace-with-a-real-password

# Note: BUSINESS_TIMEZONE (Delivery D6.1) is non-secret, so it lives in
# docker-compose.saas.yml's environment block, not here — no need to set it
# in this file.
