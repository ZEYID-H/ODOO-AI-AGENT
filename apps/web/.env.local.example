# Copy to .env.local (already git-ignored by the Next.js scaffold's own .gitignore).
# Must be prefixed NEXT_PUBLIC_ to be readable in the browser bundle.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Authentication (Phase 8E) ---------------------------------------------
# Signs/encrypts the session JWT cookie. Generate a real value with:
#   npx auth secret
# or:
#   openssl rand -base64 33
# Never reuse this placeholder as a real secret.
AUTH_SECRET=replace-with-a-real-generated-secret

# The single shared password for personal/internal access. Required — if
# unset, no one can log in (fails closed, not open).
APP_ACCESS_PASSWORD=replace-with-a-real-password
