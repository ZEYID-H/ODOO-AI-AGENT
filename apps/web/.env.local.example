# Copy to .env.local (already git-ignored by the Next.js scaffold's own .gitignore).
# Must be prefixed NEXT_PUBLIC_ to be readable in the browser bundle.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Authentication (Phase 8E) ---------------------------------------------
# Signs/encrypts the session JWT cookie. Generate a real value with:
#   npx auth secret
# or:
#   openssl rand -base64 33
# Never reuse this placeholder as a real secret.
AUTH_SECRET=replace-with-a-real-generated-secret

# The single shared password for personal/internal access. Required — if
# unset, no one can log in (fails closed, not open).
APP_ACCESS_PASSWORD=replace-with-a-real-password

# --- apps/api trust boundary (Phase 10) -------------------------------------
# Signs the short-lived token attached to every /chat and /tools call so
# apps/api can verify requests actually come from an authenticated
# session, instead of trusting anyone who can reach it on the network. See
# docs/API_AUTHENTICATION.md. MUST be set to the exact same value as
# apps/api's own API_AUTH_SECRET (repo-root .env) — this is a shared
# secret between the two services, not a per-service one. Generate with:
#   openssl rand -base64 32
# (32+ bytes — HMAC-SHA256's recommended minimum key length, RFC 7518 §3.2).
# Never reuse this placeholder as a real secret, and never reuse AUTH_SECRET
# here — they protect different trust boundaries (browser session vs.
# inter-service call) and should be independently rotatable.
API_AUTH_SECRET=replace-with-a-real-generated-secret-at-least-32-bytes
