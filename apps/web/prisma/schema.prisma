// Conversation persistence for the Odoo BI Assistant (Phase 8F).
//
// No AI/business data lives here — only conversation/message bookkeeping.
// role/content/timestamp are the only message fields, deliberately: tool
// names, parameters, and formatted-vs-lightweight distinctions are UI/API
// concerns (see apps/web/lib/history.ts), not persistence concerns.
//
// SQLite now, Postgres-ready later: every type used here (String, DateTime,
// cuid ids) is fully portable — migrating means changing `provider` and
// `DATABASE_URL` only, no field/type changes required. `String` is used for
// `role` instead of a Prisma `enum` for identical reasons of portability and
// simplicity; the allowed values are enforced at the application boundary
// (Zod-free but validated in code, mirroring the existing role: "user" |
// "assistant" union already used throughout apps/web).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Minimal identity foundation (Delivery Management D1 — see
// docs/DELIVERY_MANAGEMENT_PLAN.md §2): individual username/password
// accounts with exactly two roles. `role` is a String, not an enum, for the
// same SQLite→Postgres portability reason as Message.role; allowed values
// ("OWNER" | "DRIVER") are enforced at the application boundary
// (lib/auth-credentials.ts). Accounts are created only by the seed script
// (scripts/seed-users.ts) — there is deliberately no user-management UI.
// The pre-D1 owner keeps the id "personal-user" (seeded as username
// "admin") so existing conversation ownership survives unchanged.
model User {
  id                String                 @id @default(cuid())
  createdAt         DateTime               @default(now())
  username          String                 @unique
  passwordHash      String
  role              String // "OWNER" | "DRIVER"
  conversations     Conversation[]
  deliveryProofs    DeliveryProof[]        @relation("DriverProofs")
  reviewedProofs    DeliveryProof[]        @relation("ReviewedProofs")
  submittedAttempts DeliveryProofAttempt[] @relation("AttemptSubmitter")
  reviewedAttempts  DeliveryProofAttempt[] @relation("AttemptReviewer")

  // Driver notification read-cursor (D8 — see
  // docs/DELIVERY_MANAGEMENT_PLAN.md §9 D8). Deliberately a single nullable
  // timestamp, not a generic Notification table: Delivery events are
  // derived on read from the already-immutable DeliveryProofAttempt
  // history (see app/actions/delivery-notifications.ts), so there is
  // nothing to store per-event — only "the newest event this driver has
  // seen." NULL means "never opened the inbox" (every derived event reads
  // as unread); the D8 migration backfills every pre-existing user to the
  // migration's own execution time, so historical events do not flood
  // existing drivers as unread on upgrade. OWNER rows carry this field too
  // (uniform schema) but never read or write it — the feature is
  // DRIVER-only end to end.
  deliveryNotificationsSeenAt DateTime?
}

// Delivery Management D2 (docs/DELIVERY_MANAGEMENT_PLAN.md §5): metadata
// for a delivered-invoice proof. imagePath/mimeType/sizeBytes are nullable
// on purpose — the actual file arrives in D3; the column names abstract the
// storage backend so a later move to object storage is a data migration,
// not a schema redesign. status/role values are Strings for the same
// SQLite→Postgres portability reason as User.role and Message.role; the
// allowed values ("PENDING" | "VERIFIED" | "REJECTED") and every transition
// are enforced at the application boundary (app/actions/delivery-proofs.ts).
// verifiedAt is the review timestamp — set on rejection too, not only on
// verification.
model DeliveryProof {
  id              String    @id @default(cuid())
  invoiceNumber   String?
  customerName    String?
  notes           String?
  imagePath       String?
  mimeType        String?
  sizeBytes       Int?
  status          String    @default("PENDING") // "PENDING" | "VERIFIED" | "REJECTED"
  rejectionReason String?
  uploadedAt      DateTime  @default(now())
  verifiedAt      DateTime?

  // OCR readiness (D5 — data foundation only, no OCR engine exists yet;
  // see docs/DELIVERY_MANAGEMENT_PLAN.md §10). All extraction fields are
  // nullable; ocrStatus is a non-null String with a safe default so every
  // proof — including pre-D5 rows backfilled by the migration — reads
  // "NOT_STARTED" rather than an ambiguous null. Allowed values
  // ("NOT_STARTED" | "PROCESSING" | "COMPLETED" | "FAILED") are enforced
  // at the application boundary like every other status here. ocrConfidence
  // is 0..1. Only the owner-facing views ever expose these; driver views
  // deliberately omit them.
  ocrStatus        String    @default("NOT_STARTED")
  ocrText          String?
  ocrInvoiceNumber String?
  ocrCustomerName  String?
  ocrConfidence    Float?
  ocrProcessedAt   DateTime?
  ocrError         String?
  driverId        String
  driver          User      @relation("DriverProofs", fields: [driverId], references: [id], onDelete: Cascade)
  verifiedById    String?
  verifiedBy      User?     @relation("ReviewedProofs", fields: [verifiedById], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Immutable evidence/review history (D7 — see
  // docs/DELIVERY_MANAGEMENT_PLAN.md §9 D7). The fields above remain the
  // proof's CURRENT state (what the queue, dashboard, and image route read
  // without a join); `attempts` is the full history that current state was
  // derived from. Every proof has at least one attempt from the moment it
  // is created — see DeliveryProofAttempt's own comment.
  attempts DeliveryProofAttempt[]

  // The driver portal's hot query ("my recent uploads") and the admin
  // review queue, respectively; single-column indexes serve the D4 filters.
  @@index([driverId, uploadedAt])
  @@index([status, uploadedAt])
  @@index([invoiceNumber])
  @@index([uploadedAt])
}

// Immutable per-submission evidence and review record (D7 — Rejected Proof
// Resubmission, docs/DELIVERY_MANAGEMENT_PLAN.md §9 D7). One row per image
// a driver ever submitted for a given DeliveryProof: attempt 1 is created
// atomically with the parent proof (D2/D3's create paths, and the D2→D7
// migration backfill for every pre-D7 proof); attempt 2, 3, ... are created
// by resubmitDeliveryProof, one per resubmission, NEVER by editing an
// existing attempt row. Once written, an attempt's submission fields never
// change; its review fields (status/rejectionReason/reviewedAt/reviewedById)
// are set exactly once, when an OWNER reviews it while it is the latest
// attempt (see reviewDeliveryProof in app/actions/delivery-proofs.ts) —
// older attempts are never touched by a later review.
//
// imagePath/mimeType/sizeBytes are nullable, mirroring DeliveryProof's own
// nullable image fields: this is what makes the D7 migration's backfill
// safe for a hypothetical pre-D3 metadata-only proof (imagePath was always
// nullable on the parent; an attempt describing that same proof must be
// able to record "no image" too, not fail the migration). In practice every
// attempt created by the D3+ upload/resubmission flows has a real image —
// nullability here is a safety property of the data model, not an invitation
// to submit proofs without photos.
//
// status/role values are Strings for the same SQLite→Postgres portability
// reason as every other status field in this schema; allowed values
// ("PENDING" | "VERIFIED" | "REJECTED" — deliberately the same three as
// DeliveryProof.status, no speculative fourth state) are enforced at the
// application boundary.
model DeliveryProofAttempt {
  id              String        @id @default(cuid())
  deliveryProofId String
  deliveryProof   DeliveryProof @relation(fields: [deliveryProofId], references: [id], onDelete: Cascade)

  // The latest attempt is defined as the row with the greatest
  // attemptNumber for a given deliveryProofId — always computed server-side
  // (MAX/orderBy desc), never trusted from a client. @@unique below is both
  // the correctness constraint (no two attempts can claim the same number)
  // and the index that serves "find the latest attempt" — a separate plain
  // index on the same two columns would be redundant with the unique index
  // SQLite already builds for it, so none is added.
  attemptNumber Int

  imagePath String?
  mimeType  String?
  sizeBytes Int?

  submittedAt   DateTime @default(now())
  submittedById String
  submittedBy   User     @relation("AttemptSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)

  status          String    @default("PENDING") // "PENDING" | "VERIFIED" | "REJECTED"
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?
  reviewedBy      User?     @relation("AttemptReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deliveryProofId, attemptNumber])
  @@index([submittedById, submittedAt])
  @@index([status, submittedAt])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  // Composite, not just @@index([userId]) (Phase 9 audit follow-up):
  // listConversations() always filters by userId AND orders by updatedAt
  // desc together (app/actions/conversations.ts) — a composite index
  // serves that exact query directly instead of filtering on userId then
  // sorting separately. The userId-only lookups elsewhere (e.g.
  // findOwnedConversation's id+userId check) are still served by this
  // index's leading column. Immaterial on SQLite at today's single-account
  // scale; worth having before a Postgres migration under real load.
  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  role           String // "user" | "assistant"
  content        String
  timestamp      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
